{
  "compilerOptions": {
    "target":                  "ES2020",
    "module":                  "CommonJS",
    "lib":                     ["ES2020"],
    "outDir":                  "dist",
    "rootDirs":                ["src", "../shared/src"],
    "strict":                  false,
    "esModuleInterop":         true,
    "experimentalDecorators":  true,
    "emitDecoratorMetadata":   true,
    "resolveJsonModule":       true,
    "skipLibCheck":            true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
